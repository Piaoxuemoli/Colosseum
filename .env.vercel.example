# Vercel fallback env template
# Copy the values you actually need into the Vercel Project → Settings →
# Environment Variables dashboard. Do NOT commit real secrets.

# --- Core ---
NODE_ENV=production
BASE_URL=https://<your-project>.vercel.app

# --- Database (Supabase Postgres, pooler connection string) ---
DB_DRIVER=pg
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:6543/postgres?pgbouncer=true
# SQLite is only used for local dev; leave unset in Vercel.
# SQLITE_PATH=./dev.db

# --- Redis (Upstash REST) ---
# When UPSTASH_REDIS_REST_URL is present, the RedisLike adapter switches from
# ioredis to the Upstash REST SDK. Native pub/sub is emulated by list polling
# (~800ms latency; acceptable for the fallback path).
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>
# Legacy self-hosted ioredis URL — only set this if you still want some paths
# to talk to a real Redis instance from Vercel. Usually leave unset.
REDIS_URL=redis://placeholder:6379

# --- Match token HMAC secret (stateless) ---
# 32+ bytes of random, e.g. `openssl rand -base64 48`.
MATCH_TOKEN_SECRET=<32-byte-random>

# --- System moderator default profile (optional seed) ---
SYSTEM_MODERATOR_BASE_URL=https://api.deepseek.com/v1
SYSTEM_MODERATOR_MODEL=deepseek-chat
