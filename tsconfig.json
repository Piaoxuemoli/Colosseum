{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-build/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "archive",
    "old",
    "dist",
    ".next",
    ".next-build",
    // 测试套件重建中：vitest 尚未在 package.json 声明，遗留 *.test.ts 无法编译。
    // 待 `npm test` 恢复为真实运行器后移除以下三条。见 linting-and-quality.md。
    "**/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
