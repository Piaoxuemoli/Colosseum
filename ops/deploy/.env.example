# Colosseum production env template.
#
# Copy to `.env` on the server (next to docker-compose.yml) and fill in the
# real values. NEVER commit the filled `.env`.

# --- Public base URL (used for self-fetch tick loops and absolute links) ---
# While we're on bare IP:
BASE_URL=http://43.156.230.108
# After domain / HTTPS is live:
# BASE_URL=https://your-domain.com

# --- HMAC secret for stateless match tokens (Phase 2-2) ---
# 32+ bytes of high-entropy randomness, e.g.:
#   openssl rand -base64 48
MATCH_TOKEN_SECRET=change-me-32byte-random-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Default system moderator profile (werewolf game-master agent) ---
# You can point these at MiniMax / MiMo / DeepSeek / any OpenAI-compatible API.
# Values here are only used by the moderator seed; player agents pick their
# own profile in the UI.
SYSTEM_MODERATOR_BASE_URL=https://api.minimaxi.com/v1
SYSTEM_MODERATOR_MODEL=MiniMax-Text-01

# --- LLM API keys (match-scoped, never committed) ---
# These are consumed by client-side keyring upload on match start; they do
# not need to live in the container env. Listed here for reference only.
# MINIMAX_API_KEY=sk-cp-...
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MIMO_API_KEY=tp-...
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
